{
  "name": "zeitlich-examples",
  "private": true,
  "description": "Example app for Zeitlich – durable AI agents for Temporal",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "dev:temporal": "temporal server start-dev",
    "worker:multi-agent": "tsx watch src/examples/multi-agent/worker.ts",
    "start:multi-agent": "tsx src/examples/multi-agent/start.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.21",
    "@langchain/core": "^1.1.29",
    "@temporalio/client": "^1.15.0",
    "@temporalio/common": "^1.15.0",
    "@temporalio/plugin": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.0",
    "just-bash": "^2.11.6",
    "zeitlich": "^0.2.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@temporalio/envconfig": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bead-ai/zeitlich-examples.git"
  }
}
