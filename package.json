{
  "name": "zeitlich-examples",
  "version": "0.1.0",
  "private": true,
  "description": "Example app for Zeitlich – durable AI agents for Temporal",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "dev:temporal": "temporal server start-dev",
    "worker:multi-agent": "tsx watch src/examples/multi-agent/worker.ts",
    "start:multi-agent": "tsx src/examples/multi-agent/start.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.13",
    "@langchain/core": "^1.1.18",
    "@temporalio/client": "^1.14.1",
    "@temporalio/common": "^1.14.1",
    "@temporalio/plugin": "^1.14.1",
    "@temporalio/workflow": "^1.14.1",
    "dotenv": "^17.2.3",
    "ioredis": "^5.9.2",
    "zeitlich": "^0.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@temporalio/envconfig": "^1.14.1",
    "@temporalio/worker": "^1.14.1",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bead-ai/zeitlich-examples.git"
  }
}
